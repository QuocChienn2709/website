
{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://website-qkx3.onrender.com/api/$1"
    }
  ],
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "public",
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/success", "dest": "/success.html" },
    { "src": "/cancel", "dest": "/cancel.html" }
  ]
}
